FROM ghcr.io/ggml-org/llama.cpp:server

# Model path and server arguments are provided at runtime via `docker run` or docker-compose.
# Example:
#   docker run --rm -v $(pwd)/models/embedding:/models ghcr.io/ggml-org/llama.cpp:server \
#     server -m /models/bge-large-en-v1.5-q8_0.gguf --host 0.0.0.0 --port 8081 --embedding

# The base image ships the `server` entrypoint; no additional layers are required here.
